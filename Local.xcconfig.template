// Copy this file to Local.xcconfig (already gitignored — see .gitignore) and
// fill in your own Apple Developer Team ID to produce a signed Release
// build. Not needed for Debug builds, which self-sign ad hoc with no Apple
// Developer account or team required at all. See README.md's "Building"
// section for details.

DEVELOPMENT_TEAM[config=Release] = YOUR_TEAM_ID
