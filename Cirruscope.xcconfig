// Configuration settings file format documentation can be found at:
// https://developer.apple.com/documentation/xcode/adding-a-build-configuration-file-to-your-project

CIRRUSCOPE_BASE_BUNDLE_IDENTIFIER = de.i2h3.cirruscope
CIRRUSCOPE_BUNDLE_NAME = Cirruscope
CIRRUSCOPE_PRIVACY_POLICY_URL = https:/$()/cirruscope.app/privacy.html
CIRRUSCOPE_SUPPORT_URL = https:/$()/cirruscope.app/support.html
CODE_SIGN_IDENTITY = -
CODE_SIGN_STYLE = Automatic
CURRENT_PROJECT_VERSION = 1
DEAD_CODE_STRIPPING = YES
MACOSX_DEPLOYMENT_TARGET = 26.0
MARKETING_VERSION = 1.0.0
LOCALIZATION_PREFERS_STRING_CATALOGS = YES
SWIFT_EMIT_LOC_STRINGS = YES
SWIFT_STRICT_CONCURRENCY = complete
SWIFT_VERSION = 6.0

// Ad-hoc signing above lets CI and a fresh clone build with no Apple Developer account at all. To run on-device
// with a real "Apple Development" identity instead, copy Local.xcconfig.example to Local.xcconfig (gitignored)
// and fill in your own team — see CONTRIBUTING.md. Included last so its assignments override the ones above.
#include? "Local.xcconfig"
