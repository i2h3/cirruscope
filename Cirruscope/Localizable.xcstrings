            "state" : "translated",
            "value" : "Sesión cerrada"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déconnecté"
          }
        }
      }
    },
    "The login credentials could not be stored in the keychain (status %d)." : {
      "comment" : "Error shown when storing credentials in the macOS keychain failed; the placeholder is the numeric OSStatus.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anmeldedaten konnten nicht im Schlüsselbund gespeichert werden (Status %d)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudieron guardar las credenciales de inicio de sesión en el llavero (estado %d)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les identifiants de connexion n'ont pas pu être enregistrés dans le trousseau (statut %d)."
          }
        }
      }
    },
    "The login timed out before it was completed. Please try again." : {
      "comment" : "Error shown when the login was not completed within the allowed time.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anmeldung ist abgelaufen, bevor sie abgeschlossen wurde. Bitte versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El inicio de sesión caducó antes de completarse. Inténtalo de nuevo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion a expiré avant d'être terminée. Veuillez réessayer."
          }
        }
      }
    },
    "The login was cancelled." : {
      "comment" : "Error shown when the user dismissed the login before completing it.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Anmeldung wurde abgebrochen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El inicio de sesión se canceló."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La connexion a été annulée."
          }
        }
      }
    },
    "The login window could not be opened." : {
      "comment" : "Error shown when the Login Flow v2 authentication window could not be presented.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Das Anmeldefenster konnte nicht geöffnet werden."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pudo abrir la ventana de inicio de sesión."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La fenêtre de connexion n'a pas pu être ouverte."
          }
        }
      }
    },
    "The server returned a response that could not be understood." : {
      "comment" : "Error shown when the server's response was not a valid HTTP response.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Server hat eine Antwort zurückgegeben, die nicht verstanden werden konnte."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El servidor devolvió una respuesta que no se pudo interpretar."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le serveur a renvoyé une réponse incompréhensible."
          }
        }
      }
    },
    "The server returned an unexpected status code (%lld)." : {
      "comment" : "Error shown when the server returned an unexpected HTTP status; the placeholder is the numeric status code.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Der Server hat einen unerwarteten Statuscode zurückgegeben (%lld)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "El servidor devolvió un código de estado inesperado (%lld)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Le serveur a renvoyé un code de statut inattendu (%lld)."
          }
        }
      }
    },
    "Unsupported Server" : {
      "comment" : "Alert title shown at launch when the configured server runs a Nextcloud version older than the app supports.",
      "localizations" : {
