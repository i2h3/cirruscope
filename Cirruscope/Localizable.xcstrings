{
  "sourceLanguage" : "en",
  "strings" : {
    "“%@” already uses this shortcut." : {
      "comment" : "Tooltip on the shortcut recorder explaining which of Cirruscope's own menu items the just-rejected shortcut is already used by.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” verwendet diese Tastenkombination bereits."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” ya usa este atajo de teclado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” utilise déjà ce raccourci clavier."
          }
        }
      }
    },
    "“%@” is not a valid URL. Please check the address and try again." : {
      "comment" : "Alert message shown when the entered server address is not a valid URL; the placeholder is the address the user typed.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” ist keine gültige URL. Bitte überprüfen Sie die Adresse und versuchen Sie es erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” no es una URL válida. Comprueba la dirección y vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "“%@” n'est pas une URL valide. Veuillez vérifier l'adresse et réessayer."
          }
        }
      }
    },
    "Already Used" : {
      "comment" : "Shown briefly in the shortcut recorder when the just-pressed combination is already used by one of Cirruscope's own menu items.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bereits belegt"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ya en uso"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Déjà utilisé"
          }
        }
      }
    },
    "Cancelled" : {
      "comment" : "Status label for a download the user cancelled.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abgebrochen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cancelado"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Annulé"
          }
        }
      }
    },
    "Check your internet connection and make sure the server is online, then try again." : {
      "comment" : "Explanation shown in the web window when a page load failed.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Überprüfen Sie Ihre Internetverbindung und stellen Sie sicher, dass der Server online ist. Versuchen Sie es dann erneut."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comprueba tu conexión a internet y asegúrate de que el servidor esté en línea. Luego, vuelve a intentarlo."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vérifiez votre connexion Internet et assurez-vous que le serveur est en ligne, puis réessayez."
          }
        }
      }
    },
    "Cirruscope requires Nextcloud server version %lld or later. The server at “%@” is running version %@." : {
      "comment" : "Alert message shown when the server's Nextcloud version is too old; placeholders are the minimum supported major version, the server address, and the server's version.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope erfordert Nextcloud-Serverversion %lld oder neuer. Der Server unter “%@” verwendet Version %@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope requiere la versión %lld o posterior del servidor Nextcloud. El servidor en “%@” está ejecutando la versión %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope requiert la version %lld ou ultérieure du serveur Nextcloud. Le serveur à l'adresse “%@” exécute la version %@."
          }
        }
      }
    },
    "Cirruscope requires Nextcloud version %lld or later. The server at “%@” is running version %@." : {
      "comment" : "Alert message shown at launch when the configured server's Nextcloud version is too old; placeholders are the minimum supported major version, the server address, and the server's version.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope erfordert Nextcloud-Version %lld oder neuer. Der Server unter “%@” verwendet Version %@."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope requiere la versión %lld o posterior de Nextcloud. El servidor en “%@” está ejecutando la versión %@."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cirruscope requiert la version %lld ou ultérieure de Nextcloud. Le serveur à l'adresse “%@” exécute la version %@."
          }
        }
      }
    },
    "Could Not Reach Server" : {
