          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Serveur non pris en charge"
          }
        }
      }
    },
    "Unsupported Server Version" : {
      "comment" : "Alert title shown when the server runs a Nextcloud version older than the app supports.",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nicht unterstützte Serverversion"
